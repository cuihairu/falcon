@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# 查找依赖
find_dependency(Threads)

if(@FALCON_PACKAGE_NEEDS_SPDLOG@)
    find_dependency(spdlog)
endif()

if(@FALCON_PACKAGE_NEEDS_NLOHMANN_JSON@)
    find_dependency(nlohmann_json)
endif()

if(@FALCON_PACKAGE_NEEDS_CURL@)
    find_dependency(CURL)
endif()

if(@FALCON_PACKAGE_NEEDS_OPENSSL@)
    find_dependency(OpenSSL)
endif()

if(@FALCON_PACKAGE_NEEDS_SQLITE3@)
    find_dependency(SQLite3)
endif()

# 导入目标
include("${CMAKE_CURRENT_LIST_DIR}/FalconTargets.cmake")

check_required_components(Falcon)
