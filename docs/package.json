{
  "name": "falcon-docs",
  "version": "1.0.0",
  "description": "Falcon 下载器文档",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "docs:dev": "vitepress dev src",
    "docs:build": "vitepress build src",
    "docs:preview": "vitepress preview src",
    "docs:clean": "node -e \"const fs=require('fs'); for (const path of ['src/.vitepress/dist','src/.vitepress/cache','src/.vitepress/.temp']) fs.rmSync(path,{recursive:true,force:true})\""
  },
  "keywords": [
    "falcon",
    "downloader",
    "documentation"
  ],
  "author": "Falcon Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  }
}
